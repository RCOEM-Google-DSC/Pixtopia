rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isLoggedIn() &&
        request.auth.token.email == "rohitagrawal7974@gmail.com";
    }

    function isTeamLeader(teamId) {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/teams/$(teamId)).data.leaderId == request.auth.uid;
    }

    // ── users collection ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── teams collection ─────────────────────────────────────────────────────
    match /teams/{teamId} {
      allow read: if true;                            // public — leaderboard visible without login
      allow update: if isAdmin() ||
                       (isLoggedIn() && resource.data.leaderId == request.auth.uid);
      allow create, delete: if isAdmin();
    }

    // ── gameState (admin writes, all logged-in users read) ───────────────────
    match /gameState/{doc} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── rounds/questions (admin writes, all logged-in users read) ────────────
    match /rounds/{roundId}/questions/{questionId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── submissions (team leader writes own, admin reads all) ─────────────────
    match /submissions/{teamId} {
      allow read: if isAdmin() || isTeamLeader(teamId);
      allow write: if isTeamLeader(teamId);
    }
  }
}
